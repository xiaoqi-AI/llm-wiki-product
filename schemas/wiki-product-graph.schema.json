{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-wiki.local/schemas/wiki-product-graph.schema.json",
  "title": "llm-wiki graph data",
  "type": "object",
  "required": ["meta", "nodes", "edges"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["build_date", "wiki_title", "total_nodes", "total_edges"],
      "properties": {
        "build_date": { "type": "string" },
        "wiki_title": { "type": "string" },
        "total_nodes": { "type": "integer", "minimum": 0 },
        "total_edges": { "type": "integer", "minimum": 0 },
        "type_counts": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "title", "type", "source_path"],
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "title": { "type": "string" },
          "type": { "type": "string" },
          "community": { "type": "string" },
          "project": { "type": "string" },
          "source_path": { "type": "string" },
          "aliases": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "summary": { "type": "string" },
          "updated": { "type": "string" },
          "degree": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "type": { "type": "string" },
          "weight": { "type": "number" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
